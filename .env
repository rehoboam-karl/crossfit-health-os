# Application
APP_NAME=CrossFit Health OS
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-12345678

# Supabase (usando DB local por enquanto)
SUPABASE_URL=http://supabase-db:5432
SUPABASE_ANON_KEY=dev-anon-key
SUPABASE_SERVICE_KEY=dev-service-key

# Database (local dev)
DATABASE_URL=postgresql://postgres:postgres@supabase-db:5432/postgres

# Redis
REDIS_URL=redis://redis:6379/0

# Google Calendar (opcional para teste)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Apple (opcional para teste)
APPLE_TEAM_ID=

# Todoist (opcional para teste)
TODOIST_API_TOKEN=

# OpenAI (opcional para teste de OCR)
OPENAI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
